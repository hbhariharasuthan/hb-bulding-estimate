# OS
.DS_Store
Thumbs.db

# Secrets & environment
.env
.env.*
!.env.example
!.env.*.example
**/secrets/
*.pem
*.key

# Python (backend)
backend/__pycache__/
backend/**/__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
backend/*.egg-info/
backend/.eggs/
backend/dist/
backend/build/
backend/.venv/
backend/venv/
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/.coverage
backend/.coverage.*
backend/htmlcov/
backend/coverage.xml
backend/.tox/

# Virtual environments (repo root or elsewhere)
.venv/
venv/
ENV/
env/
.python-version

# Flutter / Dart (see also frontend/.gitignore)
frontend/build/
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages

# Reference theme workspace (keep source assets/code, ignore generated platform/build output)
frontend/theme_ref/**/build/
frontend/theme_ref/**/.dart_tool/
frontend/theme_ref/**/.packages
frontend/theme_ref/**/.flutter-plugins
frontend/theme_ref/**/.flutter-plugins-dependencies
frontend/theme_ref/**/.metadata
frontend/theme_ref/**/.idea/
frontend/theme_ref/**/.vscode/
frontend/theme_ref/**/ios/Pods/
frontend/theme_ref/**/ios/Flutter/ephemeral/
frontend/theme_ref/**/macos/Flutter/ephemeral/
frontend/theme_ref/**/linux/flutter/ephemeral/
frontend/theme_ref/**/windows/flutter/ephemeral/
frontend/theme_ref/**/android/.gradle/
frontend/theme_ref/**/android/app/build/
# Temporary imported reference app workspace (keep project root clean)
frontend/theme_ref/

# Logs
*.log
logs/

# IDE / editors
.idea/
# Uncomment to ignore local VS Code settings (team often commits launch/tasks instead):
# .vscode/
*.code-workspace
*.swp
*~

# Local Docker overrides (often contain machine-specific paths)
docker-compose.override.yml
.docker/

# Local databases
*.sqlite3
*.db

# Accidental nested project copy
hb-bulding-estimate/

# Local shell/env tooling
.envrc
.direnv/

# Test / coverage (root)
coverage/
htmlcov/
.pytest_cache/
.mypy_cache/

# Node (if tooling is added at repo root)
node_modules/

# ML / large artifacts (uncomment if you store models in-repo)
# *.pt
# *.pth
# *.onnx
# *.safetensors

# Runtime-generated storage artifacts (uploads/processed outputs)
backend/app/storage/app/public/uploads/
backend/app/storage/app/public/processed/
backend/app/storage/app/public/plans/

# Python bytecode fallback patterns
*.pyc
*.pyo
